# 复制为 .env 并填入真实 Key（.env 勿提交 Git）

# DeepSeek 示例
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# OpenAI 官方示例（二选一，删掉上面改用下面）
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 可选：也可用 OPENAI_API_KEY 变量名（与 LLM_API_KEY 二选一）
# OPENAI_API_KEY=sk-...

LLM_TEMPERATURE=0.3

# Phase 3 QQ 邮箱推送（smtp.qq.com）
EMAIL_ENABLED=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=346157791@qq.com
SMTP_PASSWORD=你的QQ邮箱授权码
NOTIFY_TO=346157791@qq.com

# 在线报告链接（GitHub Pages 启用 /docs 后填写）
REPORT_PUBLIC_BASE_URL=https://stj8888.github.io/investmentFund

# 外部 cron 触发 GitHub Actions（见 docs/外部定时触发-cron-job.org.md，勿提交真实 Token）
